{
  "name": "research-framework-ui",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev-no-turbopack": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "lint:css": "node node_modules/stylelint/bin/stylelint.mjs \"src/**/*.css\"",
    "lint:css:fix": "node node_modules/stylelint/bin/stylelint.mjs \"src/**/*.css\" --fix",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "check": "npm run lint:css && biome check .",
    "check:fix": "npm run lint:css:fix && biome check --write .",
    "cf:preview": "dotenv -e .env.staging.local -- sh -c 'opennextjs-cloudflare build && opennextjs-cloudflare preview --env=staging'",
    "cf:deploy:prod": "npm run db:push:prod && dotenv -e .env.production.local -- sh -c 'opennextjs-cloudflare build && opennextjs-cloudflare deploy --env=production'",
    "cf:deploy:staging": "npm run db:push:staging && dotenv -e .env.staging.local -- sh -c 'opennextjs-cloudflare build && opennextjs-cloudflare deploy --env=staging'",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:restart": "npm run db:stop && npm run db:start",
    "db:status": "supabase status",
    "db:reset": "supabase db reset",
    "db:push:staging": "dotenv -e .env.staging.local -- sh -c 'supabase link --project-ref \"$SUPABASE_PROJECT_REF\" && supabase db push --yes'",
    "db:push:prod": "dotenv -e .env.production.local -- sh -c 'supabase link --project-ref \"$SUPABASE_PROJECT_REF\" && supabase db push --yes'",
    "db:types:generate": "supabase gen types typescript --local 2>/dev/null > src/shared/lib/supabase/supabase.types.ts",
    "db:migration:new": "supabase migration new",
    "db:migration:generate": "node scripts/generate-migration.mjs",
    "db:migration:up": "supabase migration up"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.0-beta.39",
    "@hookform/resolvers": "^5.2.2",
    "@opennextjs/cloudflare": "^1.10.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.101.1",
    "ai": "^7.0.0-beta.113",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "next": "^16.0.9",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-hook-form": "^7.62.0",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.4.0",
    "use-debounce": "^10.1.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.16",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "stylelint": "^16.23.1",
    "stylelint-config-standard": "^39.0.0",
    "supabase": "^2.47.2",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "wrangler": "^4.0.0"
  },
  "packageManager": "npm@10.9.2"
}
