# App environment
NEXT_PUBLIC_ENV=local
NEXT_PUBLIC_APP_ENV=local

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# Supabase keys: default local keys. Replace for production.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH
SUPABASE_SECRET_KEY=sb_secret_N7UND0UgjKTVK-Uodkm0Hg_xSvEMPvz

# Google OAuth (required for sign-in)
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=your-google-client-id
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=your-google-client-secret

# Anthropic (required for all LLM calls)
ANTHROPIC_API_KEY=your-anthropic-api-key

# --- Non-local .env.{staging,production}.local --------------------------------
# These files hold non-secret per-env vars (the NEXT_PUBLIC_* block above with
# the right project URL + publishable key). Runtime secrets (SUPABASE_SECRET_KEY,
# ANTHROPIC_API_KEY) live as Cloudflare secrets via `wrangler secret put`.
#
# Required extras for remote migration push (supabase link + db push):
#   SUPABASE_PROJECT_REF=<project-ref>
# One-time setup: run `supabase login` locally so the CLI has a personal access
# token stored in ~/.supabase (migrations go through the Management API, no DB
# password needed). For CI, set SUPABASE_ACCESS_TOKEN instead.
#
# Example for .env.staging.local:
# NEXT_PUBLIC_ENV=dev
# NEXT_PUBLIC_APP_ENV=staging
# NEXT_PUBLIC_SUPABASE_URL=https://<staging-ref>.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_staging_...
# SUPABASE_PROJECT_REF=<staging-ref>
